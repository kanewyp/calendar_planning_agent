# =============================================================================
# Calendar Planning Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# --- LLM Provider ---
# Supported: anthropic, gemini, vertex_ai, openai_compatible, mock
LLM_PROVIDER=vertex_ai

# Generic key used by gemini/openai_compatible and optionally anthropic.
LLM_API_KEY=

# Backward-compatible provider-specific keys.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=

# Required for LLM_PROVIDER=vertex_ai.
# Uses Google Application Default Credentials; run:
# gcloud auth application-default login
VERTEX_PROJECT_ID=calendar-augmentation-agent
VERTEX_LOCATION=global

# Required for LLM_PROVIDER=openai_compatible.
# Examples:
# - Groq: https://api.groq.com/openai/v1
# - OpenRouter: https://openrouter.ai/api/v1
# Gemini uses this default when LLM_PROVIDER=gemini:
# https://generativelanguage.googleapis.com/v1beta/openai
LLM_BASE_URL=

# Optional; defaults are provided for anthropic, gemini, and mock.
LLM_DECOMPOSITION_MODEL=google/gemini-2.5-flash
LLM_RATIONALE_MODEL=google/gemini-2.5-flash

# --- Google Calendar OAuth ---
# Path to the OAuth client secret JSON downloaded from Google Cloud Console
GOOGLE_CLIENT_SECRET_FILE=credentials.json

# Calendar to read/write. Use "primary" for the signed-in account's main calendar.
GOOGLE_CALENDAR_ID=primary

# --- Application Settings ---
# "mock" uses hardcoded calendar data; "live" uses real Google Calendar API
CALENDAR_MODE=mock

# Default working hours (24-hour format)
DEFAULT_WORK_START=09:00
DEFAULT_WORK_END=18:00

# --- AWS (for production deployment, ignore for local dev) ---
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_SECRETS_MANAGER_SECRET_ID=
